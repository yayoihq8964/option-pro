# OpenAI Response API (required for AI analysis)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openweb-ui.xyz/v1
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_REASONING=low

# Local bind. Default is localhost-only for personal use.
HOST_BIND=127.0.0.1
PORT=2000

# Optional: set a token if you expose the app beyond localhost.
# In the browser, run:
# localStorage.setItem('optix.app.token', 'same-token-here'); location.reload();
APP_AUTH_TOKEN=
TRUST_PROXY_HEADERS=false
ALLOWED_ORIGINS=

# Massive.com (optional, not used in current version)
MASSIVE_API_KEY=

# Finnhub (optional, used by Strength Radar for company/fundamental enrichment)
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_ENRICH_LIMIT=20
FINNHUB_CANDLE_FALLBACK_ENABLED=true
FINNHUB_CANDLE_FALLBACK_LIMIT=80
STOOQ_PRICE_FALLBACK_ENABLED=true
STOOQ_PRICE_FALLBACK_LIMIT=260

# Yahoo/yfinance options broad screen (no API key)
# This runs before ranking is finalized, so option heat can promote candidates.
YAHOO_OPTIONS_ENABLED=true
YAHOO_OPTIONS_ENRICH_LIMIT=90
YAHOO_OPTION_TARGET_DTE=30
YAHOO_OPTION_MIN_DTE=14
YAHOO_OPTION_MAX_DTE=60
YAHOO_OPTION_STRIKE_WINDOW_PCT=0.16
YAHOO_OPTIONS_FAILURE_LIMIT=8

# MarketData.app (optional, used by Strength Radar for options heat)
# Official SDKs read MARKETDATA_TOKEN. MARKETDATA_API_TOKEN is also accepted by this app.
MARKETDATA_TOKEN=
MARKETDATA_BASE_URL=https://api.marketdata.app
MARKETDATA_STOCK_CANDLE_FALLBACK_ENABLED=true
MARKETDATA_STOCK_CANDLE_FALLBACK_LIMIT=260
MARKETDATA_OPTIONS_ENRICH_LIMIT=8
MARKETDATA_OPTION_DTE=30
MARKETDATA_OPTION_STRIKE_LIMIT=8
MARKETDATA_OPTION_MODE=delayed
