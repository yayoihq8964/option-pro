# OpenAI Response API (required for AI analysis)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openweb-ui.xyz/v1
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_REASONING=low

# Local bind. Default is localhost-only for personal use.
HOST_BIND=127.0.0.1
PORT=2000

# Optional: set a token if you expose the app beyond localhost.
# In the browser, run:
# localStorage.setItem('optix.app.token', 'same-token-here'); location.reload();
APP_AUTH_TOKEN=
TRUST_PROXY_HEADERS=false
ALLOWED_ORIGINS=

# Massive.com (optional, not used in current version)
MASSIVE_API_KEY=
